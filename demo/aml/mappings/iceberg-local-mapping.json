{
  "backends": {
    "iceberg": {
      "url":         "jdbc:trino://localhost:8080/iceberg",
      "user":        "admin",
      "password":    "",
      "driverClass": "io.trino.jdbc.TrinoDriver"
    }
  },
  "defaultDatasource": "iceberg",
  "vertices": {
    "Account": {
      "table": "iceberg:iceberg.aml.accounts",
      "idColumn": "id",
      "properties": {
        "accountId":   "account_id",
        "bankId":      "bank_id",
        "riskScore":   "risk_score",
        "isBlocked":   "is_blocked",
        "openedDate":  "opened_date",
        "accountType": "account_type"
      }
    },
    "Bank": {
      "table": "iceberg:iceberg.aml.banks",
      "idColumn": "id",
      "properties": {
        "bankId":      "bank_id",
        "bankName":    "bank_name",
        "countryCode": "country_code"
      }
    },
    "Country": {
      "table": "iceberg:iceberg.aml.countries",
      "idColumn": "id",
      "properties": {
        "countryCode":   "country_code",
        "countryName":   "country_name",
        "riskLevel":     "risk_level",
        "region":        "region",
        "fatfBlacklist": "fatf_blacklist"
      }
    },
    "Alert": {
      "table": "iceberg:iceberg.aml.alerts",
      "idColumn": "id",
      "properties": {
        "alertId":   "alert_id",
        "alertType": "alert_type",
        "severity":  "severity",
        "status":    "status",
        "raisedAt":  "raised_at"
      }
    }
  },
  "edges": {
    "TRANSFER": {
      "table": "iceberg:iceberg.aml.transfers",
      "idColumn": "id",
      "outColumn": "out_id",
      "inColumn":  "in_id",
      "outVertexLabel": "Account",
      "inVertexLabel":  "Account",
      "properties": {
        "transactionId": "transaction_id",
        "amount":        "amount",
        "currency":      "currency",
        "paymentFormat": "payment_format",
        "eventTime":     "event_time",
        "isLaundering":  "is_laundering"
      }
    },
    "LOCATED_IN": {
      "table": "iceberg:iceberg.aml.bank_country",
      "idColumn": "id",
      "outColumn": "out_id",
      "inColumn":  "in_id",
      "outVertexLabel": "Bank",
      "inVertexLabel":  "Country",
      "properties": {
        "isHeadquarters": "is_headquarters"
      }
    },
    "BELONGS_TO": {
      "table": "iceberg:iceberg.aml.account_bank",
      "idColumn": "id",
      "outColumn": "out_id",
      "inColumn":  "in_id",
      "outVertexLabel": "Account",
      "inVertexLabel":  "Bank",
      "properties": {
        "isPrimary": "is_primary"
      }
    },
    "SENT_VIA": {
      "table": "iceberg:iceberg.aml.account_country",
      "idColumn": "id",
      "outColumn": "out_id",
      "inColumn":  "in_id",
      "outVertexLabel": "Account",
      "inVertexLabel":  "Country",
      "properties": {
        "channelType": "channel_type",
        "routedAt":    "routed_at"
      }
    },
    "FLAGGED_BY": {
      "table": "iceberg:iceberg.aml.account_alert",
      "idColumn": "id",
      "outColumn": "out_id",
      "inColumn":  "in_id",
      "outVertexLabel": "Account",
      "inVertexLabel":  "Alert",
      "properties": {
        "flaggedAt": "flagged_at",
        "reason":    "reason"
      }
    }
  }
}

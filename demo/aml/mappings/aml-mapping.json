{
  "backends": {
    "default": {
      "url": "jdbc:h2:file:./data/graph;AUTO_SERVER=TRUE",
      "user": "sa",
      "password": ""
    }
  },
  "defaultDatasource": "default",
  "vertices": {
    "Account": {
      "table": "aml_accounts",
      "idColumn": "id",
      "properties": {
        "accountId":   "account_id",
        "bankId":      "bank_id",
        "accountType": "account_type",
        "riskScore":   "risk_score",
        "isBlocked":   "is_blocked",
        "openedDate":  "opened_date"
      }
    },
    "Bank": {
      "table": "aml_banks",
      "idColumn": "id",
      "properties": {
        "bankId":      "bank_id",
        "bankName":    "bank_name",
        "countryCode": "country_code",
        "swiftCode":   "swift_code",
        "tier":        "tier"
      }
    },
    "Transaction": {
      "table": "aml_transactions",
      "idColumn": "id",
      "properties": {
        "transactionId": "transaction_id",
        "amount":        "amount",
        "currency":      "currency",
        "paymentFormat": "payment_format",
        "eventTime":     "event_time",
        "isLaundering":  "is_laundering",
        "channel":       "channel"
      }
    },
    "Country": {
      "table": "aml_countries",
      "idColumn": "id",
      "properties": {
        "countryCode":   "country_code",
        "countryName":   "country_name",
        "riskLevel":     "risk_level",
        "region":        "region",
        "fatfBlacklist": "fatf_blacklist"
      }
    },
    "Alert": {
      "table": "aml_alerts",
      "idColumn": "id",
      "properties": {
        "alertId":   "alert_id",
        "alertType": "alert_type",
        "severity":  "severity",
        "status":    "status",
        "raisedAt":  "raised_at"
      }
    }
  },
  "edges": {
    "TRANSFER": {
      "table": "aml_transfers",
      "idColumn": "id",
      "outColumn": "from_account_id",
      "inColumn":  "to_account_id",
      "outVertexLabel": "Account",
      "inVertexLabel": "Account",
      "properties": {
        "transactionId": "transaction_id",
        "amount":        "amount",
        "currency":      "currency",
        "paymentFormat": "payment_format",
        "eventTime":     "event_time",
        "isLaundering":  "is_laundering"
      }
    },
    "BELONGS_TO": {
      "table": "aml_account_bank",
      "idColumn": "id",
      "outColumn": "account_id",
      "inColumn":  "bank_id",
      "outVertexLabel": "Account",
      "inVertexLabel": "Bank",
      "properties": {
        "since":     "since",
        "isPrimary": "is_primary"
      }
    },
    "LOCATED_IN": {
      "table": "aml_bank_country",
      "idColumn": "id",
      "outColumn": "bank_id",
      "inColumn":  "country_id",
      "outVertexLabel": "Bank",
      "inVertexLabel": "Country",
      "properties": {
        "isHeadquarters": "is_headquarters"
      }
    },
    "RECORDED_AS": {
      "table": "aml_transfer_transaction",
      "idColumn": "id",
      "outColumn": "transfer_id",
      "inColumn":  "transaction_id",
      "outVertexLabel": "Account",
      "inVertexLabel": "Transaction",
      "properties": {
        "recordedAt": "recorded_at",
        "source":     "source"
      }
    },
    "FLAGGED_BY": {
      "table": "aml_account_alert",
      "idColumn": "id",
      "outColumn": "account_id",
      "inColumn":  "alert_id",
      "outVertexLabel": "Account",
      "inVertexLabel": "Alert",
      "properties": {
        "flaggedAt": "flagged_at",
        "reason":    "reason"
      }
    },
    "SENT_VIA": {
      "table": "aml_transfer_channel",
      "idColumn": "id",
      "outColumn": "transfer_id",
      "inColumn":  "country_id",
      "outVertexLabel": "Account",
      "inVertexLabel": "Country",
      "properties": {
        "channelType": "channel_type",
        "routedAt":    "routed_at"
      }
    }
  }
}
